---
const personalData = {
    githubLink: "https://github.com/maaaseee",
    linkedinLink: "https://www.linkedin.com/in/aieta-federico/",
    email: "federicoaieta@gmail.com",
};

const icons = {
    github: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
    linkedin: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>`,
    email: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>`,
};
---

<section class="contact-section" id="contact">
    <div class="content-wrapper glass-morphism">
        <h2 class="section-title">Sobre mí & Contacto</h2>
        <div class="about-grid">
            <div class="about-text">
                <p>
                    Desarrollador Backend apasionado por construir soluciones
                    escalables y robustas. Mi enfoque principal es el ecosistema
                    Java con Spring Boot, donde busco constantemente aplicar las
                    mejores prácticas de arquitectura y diseño.
                </p>
                <p>
                    Como desarrollador junior, mi objetivo es integrarme en
                    equipos dinámicos donde pueda contribuir con mis habilidades
                    técnicas y seguir creciendo profesionalmente en el
                    desarrollo de aplicaciones de alto impacto.
                </p>
            </div>
            <div class="contact-links">
                <div class="social-group">
                    <a
                        href={personalData.githubLink}
                        target="_blank"
                        class="social-btn github"
                        title="GitHub"
                    >
                        <span class="icon" set:html={icons.github} />
                        <span class="label">GITHUB</span>
                    </a>
                    <a
                        href={personalData.linkedinLink}
                        target="_blank"
                        class="social-btn linkedin"
                        title="LinkedIn"
                    >
                        <span class="icon" set:html={icons.linkedin} />
                        <span class="label">LINKEDIN</span>
                    </a>
                    <a
                        href={`mailto:${personalData.email}`}
                        class="social-btn email"
                        title="Email"
                    >
                        <span class="icon" set:html={icons.email} />
                        <span class="label">EMAIL</span>
                    </a>
                </div>
            </div>
        </div>
        <div class="footer-hud">
            SYSTEM_LOG: SESSION_END | VERSION: 2.0.26 | ENCRYPTION: ACTIVE
        </div>
    </div>
</section>

<style>
    .contact-section {
        padding: 140px 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .content-wrapper {
        padding: 60px;
        border-bottom: 4px solid var(--color-accent);
    }

    .section-title {
        margin-bottom: 40px;
        color: var(--color-secondary);
    }

    .about-grid {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 60px;
    }

    .about-text p {
        color: var(--color-text-secondary);
        line-height: 1.8;
        margin-bottom: 20px;
        font-size: 1.1rem;
    }

    .contact-links {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .social-group {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .social-btn {
        display: flex;
        align-items: center;
        background: rgba(100, 13, 173, 0.1);
        border: 1px solid var(--color-primary);
        color: var(--color-text);
        height: 50px;
        width: 50px;
        padding: 0 14px;
        text-decoration: none;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        letter-spacing: 1px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        clip-path: polygon(0 0, 85% 0, 100% 25%, 100% 100%, 15% 100%, 0 75%);
    }

    .social-btn:hover {
        width: 160px;
        background: var(--color-primary);
        box-shadow: 0 0 20px var(--color-secondary);
    }

    .social-btn .icon {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 22px;
    }

    .social-btn .label {
        opacity: 0;
        margin-left: 15px;
        transform: translateX(-10px);
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .social-btn:hover .label {
        opacity: 1;
        transform: translateX(0);
    }

    .footer-hud {
        margin-top: 60px;
        font-size: 0.7rem;
        color: rgba(123, 0, 255, 0.4);
        text-align: center;
        font-family: var(--font-mono);
        letter-spacing: 2px;
    }

    @media (max-width: 768px) {
        .about-grid {
            grid-template-columns: 1fr;
            gap: 40px;
        }
        .content-wrapper {
            padding: 30px;
        }
        .contact-links {
            justify-content: flex-start;
        }
    }
</style>
