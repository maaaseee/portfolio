---

<div id="loader" class="loader-overlay">
    <div class="loader-content">
        <div class="loader-header">
            <span class="status-indicator"></span>
            <div class="loader-title">INICIALIZANDO SISTEMA</div>
        </div>
        <div class="progress-bar-container">
            <div class="progress-bar" id="loader-progress"></div>
        </div>
        <div class="loader-status">
            <span id="loader-percent">0%</span>
            <span class="status-msg">CARGANDO RECURSOS</span>
        </div>
    </div>
</div>

<style>
    .loader-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: #000;
        z-index: 9999;
        display: flex;
        justify-content: center;
        align-items: center;
        transition:
            opacity 0.8s ease-out,
            visibility 0.8s;
        overflow: hidden;
    }

    .loader-overlay.hidden {
        opacity: 0;
        visibility: hidden;
    }

    .loader-content {
        width: clamp(280px, 40vw, 600px);
        display: flex;
        flex-direction: column;
        gap: clamp(12px, 2vh, 24px);
    }

    .loader-header {
        display: flex;
        align-items: center;
        gap: clamp(10px, 1.5vw, 20px);
        margin-bottom: 4px;
    }

    .status-indicator {
        width: clamp(6px, 0.8vw, 12px);
        height: clamp(6px, 0.8vw, 12px);
        background-color: var(--color-accent);
        border-radius: 50%;
        box-shadow: 0 0 15px var(--color-accent);
        animation: pulse 1.5s infinite;
    }

    .loader-title {
        font-family: var(--font-header);
        color: var(--color-text);
        font-size: clamp(0.8rem, 1.5vw, 1.5rem);
        letter-spacing: 0.2em;
        opacity: 0.9;
    }

    .progress-bar-container {
        width: 100%;
        height: clamp(2px, 0.4vh, 4px);
        background: rgba(100, 13, 173, 0.1);
        position: relative;
        overflow: hidden;
    }

    .progress-bar {
        width: 0%;
        height: 100%;
        background: var(--color-accent);
        box-shadow: 0 0 15px var(--color-accent);
        transition: width 0.4s cubic-bezier(0.1, 0.5, 0.5, 1);
    }

    .loader-status {
        display: flex;
        justify-content: space-between;
        font-family: var(--font-mono);
        font-size: clamp(0.65rem, 1vw, 1rem);
        color: var(--color-secondary);
        letter-spacing: 0.1em;
        opacity: 0.8;
    }

    .status-msg {
        animation: blink 2s infinite;
    }

    @keyframes pulse {
        0% {
            opacity: 0.4;
            transform: scale(0.9);
        }
        50% {
            opacity: 1;
            transform: scale(1.1);
        }
        100% {
            opacity: 0.4;
            transform: scale(0.9);
        }
    }

    @keyframes blink {
        0%,
        100% {
            opacity: 1;
        }
        50% {
            opacity: 0.4;
        }
    }
</style>

<script>
    function updateLoader() {
        const loader = document.getElementById("loader");
        const progress = document.getElementById("loader-progress");
        const percent = document.getElementById("loader-percent");

        if (!loader || !progress || !percent) return;

        let width = 0;
        const interval = setInterval(() => {
            if (width >= 90) {
                clearInterval(interval);
            } else {
                width += Math.random() * 10;
                if (width > 90) width = 90;
                progress.style.width = width + "%";
                percent.innerText = Math.floor(width) + "%";
            }
        }, 100);

        window.addEventListener("load", () => {
            clearInterval(interval);
            progress.style.width = "100%";
            percent.innerText = "100%";

            setTimeout(() => {
                loader.classList.add("hidden");
                document.body.style.overflow = "auto";
            }, 500);
        });
    }

    // Run on every page load (including view transitions if used)
    updateLoader();
    document.addEventListener("astro:after-swap", updateLoader);
</script>
