---
import TechIcon from "./TechIcon.astro";
import { getTech } from "../data/tech";

interface ProjectLink {
    url: string;
    isPrivate?: boolean;
}

interface Project {
    title: string;
    description: string;
    tech: string[];
    type: "web" | "game" | "desktop";
    status: "DEPLOYED" | "IN PROGRESS" | "ARCHIVED" | "PRIVATE";
    links: {
        github?: ProjectLink;
        live?: ProjectLink;
        demo?: ProjectLink;
    };
}

const projects: Project[] = [
    {
        title: "Palatino",
        description:
            "Sistema integral de gestión para restaurantes con base de datos Supabase, gamificación para empleados y pedidos dinámicos.",
        tech: ["Ionic", "Angular", "NestJS", "TypeScript", "Supabase"],
        type: "web",
        status: "PRIVATE",
        links: {
            github: {
                url: "https://github.com/maaaseee/palatino-2026",
                isPrivate: true,
            },
        },
    },
    {
        title: "Pocket",
        description:
            "Aplicación de gestión financiera personal con autenticación segura y visualización de datos en tiempo real.",
        tech: ["Java", "Spring Boot", "PostgreSQL", "Angular"],
        type: "web",
        status: "IN PROGRESS",
        links: {
            github: { url: "https://github.com/maaaseee/pocket" },
            live: { url: "#" },
        },
    },
    {
        title: "ReelLit",
        description:
            "Red social dirigida al público que quiere compartir sus opiniones sobre todo medio de entretenimiento. Películas, series, libros, y más.",
        tech: ["Angular", "TypeScript", "NestJS", "MongoDB"],
        type: "web",
        status: "DEPLOYED",
        links: {
            github: {
                url: "https://github.com/maaaseee/ReelLit-RedSocial-TP2Prog4",
            },
            live: {
                url: "https://reel-lit.vercel.app/",
            },
        },
    },
    {
        title: "YoRHa Game Room",
        description:
            "Página web para videojuegos simples. Cuenta con un ahorcado, un juego de carta mayor o menor, un preguntados y un sudoku.",
        tech: ["Angular", "TypeScript", "Supabase"],
        type: "web",
        status: "ARCHIVED",
        links: {
            github: {
                url: "https://github.com/maaaseee/Yorha-SalaDeJuegos-TP1Prog4",
            },
            live: { url: "https://yorha-gameroom.vercel.app/" },
        },
    },
    {
        title: "NeonBits",
        description:
            "Página web para un autoservicio de venta de hardware. El usuario elige sus productos y pasa por caja. Dashboard para el personal sobre ventas y stock. ",
        tech: ["Javascript", "Express.js", "MySQL"],
        type: "web",
        status: "DEPLOYED",
        links: {
            github: {
                url: "https://github.com/juliancz-a/ProgIII-TP-Autoservicio",
            },
            live: {
                url: "https://neonbits.netlify.app/",
            },
        },
    },
    {
        title: "Pop The Card",
        description:
            "Juego realizado con el motor Pygame. Consiste en formar la mayor cantidad de palabras posibles con cartas que contienen una letra cada una y 90 segundos para completar el objetivo.",
        tech: ["Python"],
        type: "game",
        status: "DEPLOYED",
        links: {
            github: { url: "https://github.com/juliancz-a/SP_GRUPO_5_Pygame" },
            live: {
                url: "https://juliancz.itch.io/pop-the-card",
            },
            demo: {
                url: "https://www.youtube.com/watch?v=WkvM0X5AUk0&t",
            },
        },
    },
];

const icons = {
    github: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
    web: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
    game: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="12" x2="10" y2="12"/><line x1="8" y1="10" x2="8" y2="14"/><rect x="2" y="6" width="20" height="12" rx="2"/><line x1="15" y1="13" x2="15.01" y2="13"/><line x1="18" y1="11" x2="18.01" y2="11"/></svg>`,
    desktop: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
    demo: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>`,
};

const getLiveInfo = (type: string) => {
    switch (type) {
        case "game":
            return { label: "Jugar", icon: icons.game };
        case "desktop":
            return { label: "Descargar", icon: icons.desktop };
        default:
            return { label: "Visitar Web", icon: icons.web };
    }
};
---

<section class="projects-section" id="projects">
    <h2 class="section-title">Proyectos Seleccionados</h2>
    <div class="projects-grid">
        {
            projects.map((project) => {
                const liveInfo = getLiveInfo(project.type);
                return (
                    <div class="project-card glass-morphism spectral">
                        <div class="project-header">
                            <h3 class="project-title">{project.title}</h3>
                            <div class="project-status">
                                STATUS: {project.status}
                            </div>
                        </div>
                        <p class="project-desc">{project.description}</p>
                        <div class="project-tech">
                            {project.tech.map((t) => {
                                const tech = getTech(t);
                                return (
                                    <div class="tech-tag-wrapper">
                                        <TechIcon
                                            icon={tech.icon}
                                            name={tech.name}
                                            color={tech.color}
                                            size="48px"
                                        />
                                        <span class="tech-tooltip">
                                            {tech.name}
                                        </span>
                                    </div>
                                );
                            })}
                        </div>
                        <div class="project-links">
                            {project.links.github && (
                                <a
                                    href={
                                        project.links.github.isPrivate
                                            ? null
                                            : project.links.github.url
                                    }
                                    target="_blank"
                                    class={`btn-marathon project-link github ${project.links.github.isPrivate ? "disabled" : ""}`}
                                    title={
                                        project.links.github.isPrivate
                                            ? "Repositorio Privado"
                                            : "Ver Código"
                                    }
                                >
                                    <Fragment set:html={icons.github} />
                                    GitHub
                                </a>
                            )}
                            {project.links.live && (
                                <a
                                    href={project.links.live.url}
                                    target="_blank"
                                    class={`btn-marathon project-link live ${project.status === "IN PROGRESS" || project.status === "PRIVATE" ? "disabled" : ""}`}
                                >
                                    <Fragment set:html={liveInfo.icon} />
                                    {liveInfo.label}
                                </a>
                            )}
                            {project.links.demo && (
                                <a
                                    href={project.links.demo.url}
                                    target="_blank"
                                    class="btn-marathon project-link demo"
                                >
                                    <Fragment set:html={icons.demo} />
                                    Ver Demo
                                </a>
                            )}
                        </div>
                    </div>
                );
            })
        }
    </div>
</section>

<style>
    .projects-section {
        padding: 100px 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-title {
        text-align: center;
        margin-bottom: 60px;
        color: var(--color-primary);
        font-size: clamp(2rem, 5vw, 2.5rem);
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
        gap: 50px;
    }

    .project-card {
        padding: 40px;
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--color-secondary);
        border-right: 1px solid var(--color-secondary);
    }

    .spectral {
        background: rgba(100, 13, 173, 0.05) !important;
        box-shadow: inset 0 0 20px rgba(123, 0, 255, 0.1);
    }

    .project-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .project-title {
        font-family: var(--font-header);
        color: var(--color-accent);
        font-size: 1.5rem;
    }

    .project-status {
        font-size: 0.7rem;
        color: var(--color-secondary);
        font-family: var(--font-mono);
    }

    .project-desc {
        color: var(--color-text-secondary);
        line-height: 1.6;
        margin-bottom: 30px;
        flex-grow: 1;
    }

    .project-tech {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 30px;
    }

    .tech-tag-wrapper {
        position: relative;
        transition: transform 0.2s ease;
    }

    .tech-tag-wrapper:hover {
        transform: translateY(-3px);
    }

    .tech-tooltip {
        position: absolute;
        bottom: 120%;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        background: rgba(10, 10, 10, 0.9);
        color: var(--color-accent);
        padding: 4px 10px;
        border: 1px solid var(--color-primary);
        font-size: 0.9rem;
        font-family: var(--font-mono);
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 100;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.8);
    }

    .tech-tooltip::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-top-color: var(--color-primary);
    }

    .tech-tag-wrapper:hover .tech-tooltip {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }

    .project-links {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .project-link {
        font-size: 0.8rem;
        min-width: 140px;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .project-link :global(svg) {
        transition: transform 0.3s ease;
    }

    .project-link:hover :global(svg) {
        transform: translateY(-2px);
    }

    .project-link.disabled {
        opacity: 0.5;
        cursor: not-allowed;
        pointer-events: none;
        filter: grayscale(1);
    }

    @media (max-width: 768px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
