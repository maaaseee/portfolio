---
import Layout from "../layouts/Layout.astro";
import Background3D from "../components/Background3D.astro";
import Hero from "../components/Hero.astro";
import Timeline from "../components/Timeline.astro";
import TechStack from "../components/TechStack.astro";
import Projects from "../components/Projects.astro";
import AboutContact from "../components/AboutContact.astro";
import { fetchGitHubData } from "../utils/github";

const githubData = await fetchGitHubData("maaaseee");

const data = {
    name: "Federico Aieta",
    role: "Java Backend Developer",
    stackSummary: "JAVA | SPRING BOOT | ANGULAR | POSTGRESQL",
    github: githubData,
};
---

<Layout title={`${data.name} | Portfolio`}>
    <Background3D />

    <main class="portfolio-main">
        <div class="hud-overlay hud-bottom-left">SESSION_ACTIVE: TRUE</div>
        <div class="hud-overlay hud-bottom-right">
            LOC: {githubData?.location.toUpperCase() || "BUENOS_AIRES_AR"}
        </div>

        <Hero {...data} />
        <TechStack />
        <Timeline />
        <Projects />
        <AboutContact />
    </main>

    <div class="scanline"></div>
</Layout>

<style>
    .portfolio-main {
        position: relative;
        z-index: 1;
        width: 100%;
        overflow: visible;
    }

    /* Global Scroll Smooth */
    :global(html) {
        scroll-behavior: smooth;
    }
</style>
